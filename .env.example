# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Base URL where this server is deployed (no trailing slash)
BASE_URL=https://your-app.onrender.com

# Secret key for signing session tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-this-to-a-random-secret-key

# Directory to store user tokens (Render uses /tmp or a persistent disk)
TOKEN_STORAGE_DIR=/tmp/ga_tokens

# Optional: restrict OAuth to specific Google accounts (comma-separated emails)
# Leave empty to allow any Google account
ALLOWED_EMAILS=

# Port (Render sets this automatically)
PORT=8000
